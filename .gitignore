# ════════════════════════════════════════════════════════
# AgentDir x Achii — Sovereign .gitignore
# ════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/
venv/
uv.lock

# ── Environment ──
.env
.env.secure
*.backup

# ── Runtime Data ──
memory/chroma/
memory/task_history.jsonl
evolution.log
swarm/
scratch/

# ── User Data ──
Inbox/*
Outbox/*
!Inbox/.gitkeep
!Outbox/.gitkeep

# ── Workspace (local only) ──
workspace/archive/
workspace/visuals/
workspace/__pycache__/

# ── Models (large binary) ──
*.gguf
*.bin
*.safetensors

# ── Media Bloat Guard ──
# Only allow specific images via git add -f
workspace/**/*.png
workspace/**/*.jpg
workspace/**/*.mp4
workspace/**/*.webm
workspace/**/*.webp

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──
.vscode/
.idea/
*.swp
*~

# ── Desktop / Tauri ──
desktop/node_modules/
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/dist/

# ── Misc ──
outputs/
raw/
*.log
