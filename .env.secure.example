# Kopioi: cp .env.secure.example .env.secure  (tai copy Windowsissa)
# Kaytto: docker compose -f docker-compose.yml -f docker-compose.secure.yml up --build
#
# AGENTDIR_SESSION_SECRET vahintaan 16 merkkia (tai jata tyhjaksi: kaytetaan AGENTDIR_UI_SECRET-pohjaista tiivistetta)

AGENTDIR_UI_SECRET=muuta-tama-pitkaksi-satunnaiseksi
AGENTDIR_API_SECRET=muuta-tama-a2a-post-pyynnoille
AGENTDIR_SESSION_SECRET=muuta-tama-vahintaan-16-merkkia
