{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Achii Sovereign Engine",
  "version": "4.2.0",
  "identifier": "com.agentdir.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Achii Sovereign Engine v4.2",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "url": "http://localhost:5173"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"]
  }
}
