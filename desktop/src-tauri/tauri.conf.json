{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign Engine",
  "version": "4.1.0",
  "identifier": "com.agentdir.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "AgentDir × Achii — Sovereign Engine",
        "width": 1360,
        "height": 880,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"]
  }
}
