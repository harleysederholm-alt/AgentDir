# AgentDir Sovereign Engine 4.0 — Docker Hub -valmis kontti
# Multi-stage build: pienempi tuotantoimage
# Sandbox-eristys: --network none subprocess-tasolla

# ── Vaihe 1: Riippuvuudet (builder) ─────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

# Järjestelmäriippuvuudet
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ── Vaihe 2: Runtime ────────────────────────────────────────────────────
FROM python:3.12-slim

LABEL maintainer="AgentDir Sovereign Team"
LABEL version="4.0-rc1"
LABEL description="AgentDir Sovereign Engine — 100% lokaali AI-ekosysteemi"

WORKDIR /app

# Kopioi asennetut paketit builderista
COPY --from=builder /install /usr/local

# Kopioi koko sovellus — kaikki ydinmoduulit
COPY *.py ./
COPY config.json manifest.json ./

# Uudet v3.5.1+ moduulit
COPY workspace/ ./workspace/
COPY workflows/ ./workflows/
COPY sandbox/ ./sandbox/
COPY .prompts/ ./.prompts/

# Tukitiedostot
COPY docs/ ./docs/
COPY web/ ./web/
COPY templates/ ./templates/

# Luo kansiorakenne
RUN mkdir -p raw wiki outputs Inbox Outbox memory plugins swarm

# Kopioi entrypoint
COPY docker-entrypoint-35.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Healthcheck: tarkista A2A-rajapinta
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/status')" || exit 1

# Volume: agenttikansio mountataan ulkoa kehityksessä
VOLUME ["/app/Inbox", "/app/Outbox", "/app/memory", "/app/outputs"]

# Ympäristömuuttujat
ENV AGENTDIR_DEFAULT_MODEL=ollama/gemma4:e4b
ENV OLLAMA_HOST=http://host.docker.internal:11434/v1
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

EXPOSE 8080

ENTRYPOINT ["/entrypoint.sh"]
CMD ["status"]
